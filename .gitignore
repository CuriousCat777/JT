# OS
.DS_Store
Thumbs.db

# Test / Coverage
.coverage
htmlcov/
.pytest_cache/

# Credentials & tokens (never commit)
credentials.json
token.json
*.backup.json

# Claude workspace — ignore everything except shared config
.claude/*
