*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment variables (sensitive)
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
logs/*
!logs/.gitkeep

# Encrypted data stores
*.enc
*.key
data/secure/

# Runtime evaluation data
data/evaluations.jsonl

