# GREG Server Environment Variables

# Database
DATABASE_URL=postgresql://localhost:5432/greg

# Encryption (base64-encoded 256-bit key for AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=your-base64-encoded-256-bit-key-here

# CMS Developer API
CMS_API_KEY=your-cms-api-key

# SAM.gov API
SAM_API_KEY=your-sam-gov-api-key

# Epic FHIR (Sandbox)
EPIC_FHIR_CLIENT_ID=your-epic-client-id
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4

# CAQH ProView
CAQH_USERNAME=your-caqh-username
CAQH_PASSWORD=your-caqh-password

# Stripe (Billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRY=24h

# Server
PORT=3000
NODE_ENV=development
