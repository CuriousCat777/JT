# Secrets — NEVER include in image
.env
config/google_credentials.json
config/google_token.json
*.pem
*.key

# Runtime data — mounted as volumes instead
data/
logs/

# Development
.git
.github
.pytest_cache
__pycache__
*.pyc
*.pyo
.mypy_cache
.ruff_cache
*.egg-info
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docs (not needed in container)
docs/
*.md
!requirements.txt

# Tests (not needed in production image)
tests/
