# Guardian One — Environment Variables
# ======================================
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.

# --- General ---
GUARDIAN_DATA_DIR=data
GUARDIAN_LOG_DIR=logs
GUARDIAN_MASTER_PASSPHRASE=changeme_use_a_strong_passphrase

# --- Google Calendar ---
# 1. Enable Calendar API in Google Cloud Console
# 2. Create OAuth 2.0 credentials (Desktop app)
# 3. Download JSON → save as config/google_credentials.json
# 4. Run: python main.py --calendar-auth  (opens browser, saves token)
GOOGLE_CALENDAR_CREDENTIALS=config/google_credentials.json
GOOGLE_CALENDAR_TOKEN=config/google_token.json

# --- Epic FHIR ---
EPIC_FHIR_BASE_URL=
EPIC_CLIENT_ID=

# --- Rocket Money ---
ROCKET_MONEY_API_KEY=

# --- Teller (preferred — direct bank API, no browser widget) ---
# 1. Sign up at teller.io, create an application
# 2. Enroll accounts via Teller Connect
# 3. Copy your access token here
TELLER_ACCESS_TOKEN=
TELLER_ENVIRONMENT=sandbox

# --- Plaid (alternative — requires browser OAuth) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- NordVPN ---
NORDVPN_TOKEN=

# --- DeleteMe ---
DELETEME_API_KEY=

# --- DoorDash ---
DOORDASH_DEVELOPER_ID=
DOORDASH_KEY_ID=
DOORDASH_SIGNING_SECRET=

# --- Notion ---
# 1. Create an internal integration at https://www.notion.so/my-integrations
# 2. Grant it access to your target workspace pages
# 3. Copy the "Internal Integration Secret" (starts with ntn_)
# 4. Set NOTION_ROOT_PAGE_ID to the page ID where dashboards will be created
#    (the hex ID at the end of any Notion page URL)
NOTION_TOKEN=
NOTION_ROOT_PAGE_ID=

# --- Notifications (Email) ---
# Gmail App Password: https://myaccount.google.com/apppasswords
GMAIL_FROM=jeremytabernero@gmail.com
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL=jeremytabernero@gmail.com

# --- Notifications (SMS, optional) ---
# Sign up at https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
NOTIFY_PHONE=
