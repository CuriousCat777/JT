# Guardian One — Environment Variables
# ======================================
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.

# --- General ---
GUARDIAN_DATA_DIR=data
GUARDIAN_LOG_DIR=logs
GUARDIAN_MASTER_PASSPHRASE=changeme_use_a_strong_passphrase

# --- Google Calendar ---
GOOGLE_CALENDAR_CREDENTIALS=config/google_credentials.json

# --- Epic FHIR ---
EPIC_FHIR_BASE_URL=
EPIC_CLIENT_ID=

# --- Rocket Money ---
ROCKET_MONEY_API_KEY=

# --- Plaid (alternative) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- NordVPN ---
NORDVPN_TOKEN=

# --- DeleteMe ---
DELETEME_API_KEY=
